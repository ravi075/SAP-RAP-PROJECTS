projection;
strict ( 2 );
use side effects;
define behavior for ZC_USER alias User //alias <alias_name>
{
  use create;
  use update;
  use delete;

  use action uploadExcelData;
  use action DownloadExcel;

  use association _UserDev { create; }
}

define behavior for ZC_USER_DEV alias UserDev//alias <alias_name>
{
  use update;
  use delete;

  use association _User;
}